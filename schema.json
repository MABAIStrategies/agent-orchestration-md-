{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Orchestration Skill Schema",
  "description": "Formal schema for the Agent Orchestration skill, enabling validation and cross-platform integration",
  "type": "object",
  "required": [
    "skill_id",
    "name",
    "version",
    "protocols"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^[a-z-]+$",
      "description": "Unique identifier for the skill (lowercase, hyphen-separated)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic versioning (major.minor.patch)"
    },
    "author": {
      "type": "string",
      "description": "Author or organization name"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief description of the skill's purpose"
    },
    "category": {
      "type": "string",
      "enum": [
        "system-prompt",
        "workflow",
        "tool-integration",
        "content-generation",
        "analysis",
        "automation",
        "other"
      ],
      "description": "Skill category"
    },
    "protocols": {
      "type": "array",
      "minItems": 1,
      "description": "Core protocols defined by this skill",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "trigger_keywords",
          "applied_to"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z-]+$",
            "description": "Unique protocol identifier"
          },
          "name": {
            "type": "string",
            "description": "Protocol name"
          },
          "description": {
            "type": "string",
            "description": "What this protocol does"
          },
          "trigger_keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Keywords that activate this protocol"
          },
          "applied_to": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "design",
                "code",
                "documentation",
                "workflow",
                "management",
                "communication"
              ]
            },
            "description": "Domains where this protocol applies"
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "constraint",
                "rationale"
              ],
              "properties": {
                "constraint": {
                  "type": "string",
                  "description": "The constraint (e.g., 'NO pure black color')"
                },
                "rationale": {
                  "type": "string",
                  "description": "Why this constraint exists"
                },
                "override_keyword": {
                  "type": "string",
                  "description": "Keyword to override this constraint (e.g., 'DRAFT MODE')"
                }
              }
            },
            "description": "Specific constraints enforced by this protocol"
          },
          "success_metrics": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "How to measure if protocol is working"
          }
        }
      }
    },
    "triggers": {
      "type": "object",
      "description": "When and how the skill activates",
      "properties": {
        "automatic_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keywords that auto-activate the skill"
        },
        "manual_command": {
          "type": "string",
          "description": "Command to manually invoke skill"
        },
        "default_active": {
          "type": "boolean",
          "description": "Whether skill is active by default"
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "description": "Priority in context window"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "description": "Platform and version compatibility",
      "properties": {
        "min_version": {
          "type": "string",
          "description": "Minimum AI model/platform version"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Compatible platforms (e.g., 'claude.ai', 'Claude API', 'OpenAI')"
        },
        "requires_context_window": {
          "type": "integer",
          "description": "Minimum context window size in tokens"
        }
      }
    },
    "integration": {
      "type": "object",
      "description": "Integration with other skills",
      "properties": {
        "requires_skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Skills this one depends on"
        },
        "works_with_skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Skills this one complements"
        },
        "conflicts_with_skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Skills that may conflict"
        }
      }
    },
    "overrides": {
      "type": "object",
      "description": "Keywords that override or modify skill behavior",
      "properties": {
        "disable_all": {
          "type": "string",
          "description": "Keyword to temporarily disable all constraints"
        },
        "draft_mode": {
          "type": "string",
          "description": "Keyword to enter draft/relaxed mode"
        },
        "simple_mode": {
          "type": "string",
          "description": "Keyword for simplified/minimal application"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "last_updated": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Searchable tags"
        },
        "support_url": {
          "type": "string",
          "format": "uri",
          "description": "Support or documentation URL"
        },
        "maintainer_email": {
          "type": "string",
          "format": "email",
          "description": "Contact for issues or questions"
        }
      }
    }
  },
  "examples": [
    {
      "skill_id": "agent-orchestration",
      "name": "Agent Orchestration",
      "version": "1.0.0",
      "author": "MAB AI Strategies LLC",
      "description": "Protocols for managing the agentic environment",
      "category": "system-prompt",
      "protocols": [
        {
          "id": "skill-sweet-spot",
          "name": "Skill Sweet Spot Protocol",
          "description": "Maintain 5-15 active skills to prevent context bloat",
          "trigger_keywords": [
            "skill count",
            "context bloat",
            "archiving"
          ],
          "applied_to": [
            "management"
          ],
          "constraints": [
            {
              "constraint": "Maintain 5-15 active skills",
              "rationale": "Prevents context bloat and instruction conflict",
              "override_keyword": "EXPAND_SKILLS"
            }
          ]
        }
      ],
      "triggers": {
        "automatic_keywords": [
          "agent",
          "orchestration",
          "skill management"
        ],
        "default_active": true,
        "priority": "high"
      }
    }
  ]
}
